generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      String
  createdAt DateTime   @default(now())
  donations Donation[]
  ngo       NGO?
}

model NGO {
  id                 String     @id @default(uuid())
  userId             String     @unique
  organizationName   String
  description        String
  contactInfo        String?
  verificationDocUrl String?
  verificationStatus String
  campaigns          Campaign[]
  user               User       @relation(fields: [userId], references: [id])
}

model Campaign {
  id                String         @id @default(uuid())
  ngoId             String
  title             String
  description       String
  goalAmount        Float
  raisedAmount      Float          @default(0)
  imageUrl          String?
  category          String
  status            String
  transparencyScore Float          @default(0)
  verificationDocUrl String?
  createdAt         DateTime       @default(now())
  ngo               NGO            @relation(fields: [ngoId], references: [id])
  donations         Donation[]
  fraudReports      FraudReport[]
  impactUpdates     ImpactUpdate[]
}

model Donation {
  id         String   @id @default(uuid())
  userId     String
  campaignId String
  amount     Float
  status     String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model ImpactUpdate {
  id          String   @id @default(uuid())
  campaignId  String
  title       String
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
}

model FraudReport {
  id         String   @id @default(uuid())
  campaignId String
  reportedBy String
  reason     String
  status     String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
}
